{
  "enabled": true,
  "name": "Harness Continuous .NET Validation (edit)",
  "description": "When any C# source or project file is saved (e.g. by a running Antigravity agent), build and test all .NET solutions via the shared validate-quick script.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.cs",
      "**/*.csproj",
      "**/*.sln"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "bash scripts/validate-quick.sh dotnet"
  }
}