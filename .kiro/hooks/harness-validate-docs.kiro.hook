{
  "enabled": true,
  "name": "Harness CRM Docs Validator",
  "description": "When any docs markdown file is saved, run the portable CRM docs validation script, then commit the docs stage to git.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "docs/**/*.md"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "bash scripts/validate-crm-docs.sh && bash scripts/harness-commit.sh docs \"docs updated\""
  }
}