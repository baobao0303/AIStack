# Identity.Api environment configuration TEMPLATE.
# Copy to `.env` (gitignored) or export these in your shell. NEVER commit real secrets.
#
# .NET maps double-underscore (__) env vars onto nested config keys, so these
# OVERRIDE appsettings.json without editing any tracked file.

# --- PostgreSQL (e.g. Supabase) ---
# Supabase requires SSL. Fill Password with your CURRENT (rotated) credential.
ConnectionStrings__DefaultConnection=Host=YOUR_SUPABASE_HOST;Port=5432;Database=postgres;Username=postgres;Password=REPLACE_WITH_ROTATED_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# --- Redis session/cache store ---
ConnectionStrings__RedisConnection=localhost:6379

# --- JWT signing (do NOT rely on the hardcoded fallback in code) ---
Jwt__Secret=REPLACE_WITH_A_LONG_RANDOM_SECRET
Jwt__Issuer=Identity.Api
Jwt__Audience=CRMPortal
