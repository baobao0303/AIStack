{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "tenant-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/tenant/{**catch-all}"
        }
      },
      "ecommerce-products-route": {
        "ClusterId": "ecommerce-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "ecommerce-products-v1-route": {
        "ClusterId": "ecommerce-cluster",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}"
        }
      },
      "ecommerce-categories-v1-route": {
        "ClusterId": "ecommerce-cluster",
        "Match": {
          "Path": "/api/v1/categories/{**catch-all}"
        }
      },
      "ecommerce-inventory-v1-route": {
        "ClusterId": "ecommerce-cluster",
        "Match": {
          "Path": "/api/v1/inventory/{**catch-all}"
        }
      },
      "ecommerce-orders-route": {
        "ClusterId": "ecommerce-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "chat-hub-route": {
        "ClusterId": "crmchat-cluster",
        "Match": {
          "Path": "/hubs/chat/{**catch-all}"
        }
      },
      "chat-sessions-route": {
        "ClusterId": "crmchat-cluster",
        "Match": {
          "Path": "/api/chatsessions/{**catch-all}"
        }
      },
      "chat-employees-route": {
        "ClusterId": "crmchat-cluster",
        "Match": {
          "Path": "/api/employees/{**catch-all}"
        }
      },
      "chat-shifts-route": {
        "ClusterId": "crmchat-cluster",
        "Match": {
          "Path": "/api/shifts/{**catch-all}"
        }
      },
      "chat-ai-route": {
        "ClusterId": "crmchat-cluster",
        "Match": {
          "Path": "/api/ai/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5118"
          }
        }
      },
      "ecommerce-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5169"
          }
        }
      },
      "crmchat-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5125"
          }
        }
      }
    }
  }
}
