{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "tenant-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/tenant/{**catch-all}"
        }
      },
      "ecommerce-products-route": {
        "ClusterId": "ecommerce-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "ecommerce-orders-route": {
        "ClusterId": "ecommerce-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5118"
          }
        }
      },
      "ecommerce-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5169"
          }
        }
      }
    }
  }
}
