{
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tiem-nha-zit/shared": ["libs/shared/src/index.ts"],
      "@tiem-nha-zit/shared/*": ["libs/shared/*"],
      "@tiem-nha-zit/shared-react": ["libs/shared-react/src/index.ts"],
      "@tiem-nha-zit/shared-react/*": ["libs/shared-react/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
