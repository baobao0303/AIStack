{
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tiem-nha-zit/shared-ui": ["libs/shared-ui/src/index.ts"],
      "@tiem-nha-zit/shared-types": ["libs/shared-types/src/index.ts"],
      "@tiem-nha-zit/shared-utils": ["libs/shared-utils/src/index.ts"],
      "@tiem-nha-zit/shared-auth": ["libs/shared-auth/src/index.ts"],
      "@tiem-nha-zit/shared-api": ["libs/shared-api/src/index.ts"],
      "@tiem-nha-zit/shared-layout": ["libs/shared-layout/src/index.ts"],
      "@tiem-nha-zit/shared-config": ["libs/shared-config/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
