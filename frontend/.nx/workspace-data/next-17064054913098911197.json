{
  "11509389886167622091": {
    "build": {
      "command": "next build",
      "options": {
        "cwd": "apps/storefront-web",
        "tty": false
      },
      "dependsOn": [
        "^build"
      ],
      "cache": true,
      "inputs": [
        "default",
        "^default",
        {
          "externalDependencies": [
            "next"
          ]
        }
      ],
      "outputs": [
        "{workspaceRoot}/apps/storefront-web/.next",
        "{workspaceRoot}/apps/storefront-web/.next/!(cache)"
      ]
    },
    "dev": {
      "command": "next dev",
      "options": {
        "cwd": "apps/storefront-web"
      }
    },
    "start": {
      "command": "next start",
      "options": {
        "cwd": "apps/storefront-web"
      },
      "dependsOn": [
        "build"
      ]
    },
    "serve-static": {
      "command": "next start",
      "options": {
        "cwd": "apps/storefront-web"
      },
      "dependsOn": [
        "build"
      ]
    },
    "build-deps": {
      "dependsOn": [
        "^build"
      ]
    },
    "watch-deps": {
      "dependsOn": [
        "build-deps"
      ],
      "command": "npx nx watch --projects storefront-web --includeDependentProjects -- npx nx build-deps storefront-web"
    }
  },
